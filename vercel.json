{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "installCommand": "pip install --no-cache-dir --force-reinstall -r requirements.txt",
        "buildCommand": "pip install --no-cache-dir --force-reinstall -r requirements.txt"
      }
    }
  ],
  "routes": [{"src": "/(.*)", "dest": "app.py"}]
}
